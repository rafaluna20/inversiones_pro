# ====================================
# CONFIGURACIÓN DE SEGURIDAD - FASE 1
# ====================================

# ENCRIPTACIÓN DE DATOS
# Clave de 256 bits para encriptar datos sensibles (montos, IDs, información personal)
# Genera una nueva con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=genera-una-clave-segura-de-32-bytes-aqui

# Salt para hashing (cambiar en producción)
ENCRYPTION_SALT=terra-lima-salt-2026-change-this

# REDIS - Rate Limiting
# URL de conexión a Redis (local o remoto)
REDIS_URL=redis://localhost:6379

# IPs permitidas sin rate limiting (opcional, separadas por comas)
RATE_LIMIT_WHITELIST=127.0.0.1,::1

# FIREBASE
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ODOO WALLET API
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_API_USER=admin
ODOO_API_PASSWORD=admin

# JWT para autenticación
JWT_SECRET=genera-un-secreto-jwt-aqui
JWT_EXPIRES_IN=7d

# ENTORNO
NODE_ENV=development

# ====================================
# CONFIGURACIÓN OPCIONAL - FASE 2
# ====================================

# Sentry (APM/Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Cloud Logging
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Webhooks para notificaciones
# WEBHOOK_SLACK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# WEBHOOK_DISCORD=https://discord.com/api/webhooks/YOUR/WEBHOOK
